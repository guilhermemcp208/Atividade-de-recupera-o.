programa
{
    funcao inicio()
    {
        inteiro totalDias
        inteiro anos, meses, dias

        escreva("Digite a idade em dias: ")
        leia(totalDias)

        anos = totalDias / 365
        totalDias = totalDias % 365

        meses = totalDias / 30
        dias = totalDias % 30

        escreva("\nAnos: ", anos)
        escreva("\nMeses: ", meses)
        escreva("\nDias: ", dias)
    }
}
