programa
{
	funcao inicio()
	{
		real indice

		escreva("Digite o índice de poluição: ")
		leia(indice)

		se (indice >= 0.5)
		{
			escreva("Suspender atividades dos grupos 1, 2 e 3.")
		}
		senao se (indice >= 0.4)
		{
			escreva("Suspender atividades dos grupos 1 e 2.")
		}
		senao se (indice >= 0.3)
		{
			escreva("Suspender atividades do grupo 1.")
		}
		senao
		{
			escreva("Índice dentro do limite aceitável.")
		}
	}
}
