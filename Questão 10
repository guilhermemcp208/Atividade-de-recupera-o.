programa
{
    funcao inicio()
    {
        real a, b, c
        real maior

        escreva("Digite o primeiro valor: ")
        leia(a)

        escreva("Digite o segundo valor: ")
        leia(b)

        escreva("Digite o terceiro valor: ")
        leia(c)

        maior = a

        se (b > maior)
        {
            maior = b
        }

        se (c > maior)
        {
            maior = c
        }

        escreva("\nO maior valor é: ", maior)
    }
}
