programa
{
    funcao inicio()
    {
        inteiro segundos, horas, minutos, resto

        escreva("Digite o tempo em segundos: ")
        leia(segundos)

        horas = segundos / 3600
        resto = segundos % 3600

        minutos = resto / 60
        segundos = resto % 60

        escreva("\nHoras: ", horas)
        escreva("\nMinutos: ", minutos)
        escreva("\nSegundos: ", segundos)
    }
