programa
{
    funcao inicio()
    {
        inteiro a, b

        escreva("Digite o primeiro valor: ")
        leia(a)

        escreva("Digite o segundo valor: ")
        leia(b)

        se (a % b == 0 ou b % a == 0)
        {
            escreva("São múltiplos.")
        }
        senao
        {
            escreva("Não são múltiplos.")
        }
    }
}
