programa
{
	funcao inicio()
	{
		inteiro codigo, quantidade
		real total

		escreva("Código do lanche: ")
		leia(codigo)

		escreva("Quantidade: ")
		leia(quantidade)

		escolha (codigo)
		{
			caso 100:
				total = quantidade * 1.20
				pare

			caso 101:
				total = quantidade * 1.30
				pare

			caso 102:
				total = quantidade * 1.50
				pare

			caso 103:
				total = quantidade * 1.20
				pare

			caso 104:
				total = quantidade * 1.30
				pare

			caso 105:
				total = quantidade * 1.00
				pare

			caso contrario:
				escreva("Código inválido!")
				retorne
		}

		escreva("Total a pagar: R$ ", total)
	}
}
